#info
j           next-line
k           prev-line
l           forward-char
h           backward-char
o           history-node
# Bind to Ctrl-e to scroll down 1 line (Vim style)
J        down-line

# Bind to Ctrl-y to scroll up 1 line (Vim style)
K        up-line
#info
# Single key window switching/splitting
O           prev-window
s           split-window
x           delete-window
#echo
